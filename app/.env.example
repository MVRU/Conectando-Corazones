# URL base del proyecto Supabase
PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co

# Clave anon pública de Supabase usada por SvelteKit SSR y cliente
PUBLIC_SUPABASE_ANON_KEY=tu_supabase_anon_key


# ==========================================
# Variables privadas (no compartir valores reales)
# ==========================================

# URL pooler de PostgreSQL usada por Prisma en runtime local.
DATABASE_URL=postgresql://postgres.<project-ref>:<db-password>@<pooler-host>:6543/postgres

# URL directa de PostgreSQL para migraciones Prisma y tareas DDL.
DIRECT_URL=postgresql://postgres:<db-password>@db.<project-ref>.supabase.co:5432/postgres

# Clave service role de Supabase.
# Requerida para registro, auth admin, uploads firmados y storage server-side.
SUPABASE_SERVICE_ROLE_KEY=tu_supabase_service_role_key
