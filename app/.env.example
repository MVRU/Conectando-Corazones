# Base de datos (Supabase / Prisma)
DATABASE_URL=
DB_POOLER_URL=
DIRECT_URL=

# Supabase
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google (IA)
GOOGLE_API_KEY=

# Notificaciones email a administradores (Resend)
# Obligatoria para envío real. Sin ella, las notificaciones se omiten silenciosamente.
RESEND_API_KEY=
# Remitente visible. Por defecto usa onboarding@resend.dev (shared domain de Resend).
# Para producción: verificar un dominio en resend.com/domains y usar un email de ese dominio.
ADMIN_ALERTS_EMAIL_FROM=
# Destinatarios separados por coma. Si no se define, el sistema consulta la DB
# buscando usuarios activos con rol=administrador que tengan email registrado.
ADMIN_ALERTS_EMAILS=
# URL base para construir links al panel admin en los emails (ej. https://tuapp.com)
APP_BASE_URL=
